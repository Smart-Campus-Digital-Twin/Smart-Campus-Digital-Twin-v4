{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "green", "value": 3600 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "time() - node_boot_time_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU cores",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "count(count(node_cpu_seconds_total{instance=~\"$instance\"}) by (cpu))" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load 1m",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "node_load1{instance=~\"$instance\"}" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Memory used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}))" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Root disk used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "100 * (1 - node_filesystem_avail_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"})" }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Instances up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(up{job=\"node\"})" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU usage by mode",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "avg by (mode) (rate(node_cpu_seconds_total{instance=~\"$instance\",mode!=\"idle\"}[5m])) * 100", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Load average",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "node_load1{instance=~\"$instance\"}",  "legendFormat": "1m  {{instance}}" },
        { "refId": "B", "expr": "node_load5{instance=~\"$instance\"}",  "legendFormat": "5m  {{instance}}" },
        { "refId": "C", "expr": "node_load15{instance=~\"$instance\"}", "legendFormat": "15m {{instance}}" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Memory usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}", "legendFormat": "used" },
        { "refId": "B", "expr": "node_memory_Buffers_bytes{instance=~\"$instance\"}", "legendFormat": "buffers" },
        { "refId": "C", "expr": "node_memory_Cached_bytes{instance=~\"$instance\"}", "legendFormat": "cached" },
        { "refId": "D", "expr": "node_memory_MemFree_bytes{instance=~\"$instance\"}", "legendFormat": "free" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Swap usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "node_memory_SwapTotal_bytes{instance=~\"$instance\"} - node_memory_SwapFree_bytes{instance=~\"$instance\"}", "legendFormat": "used {{instance}}" },
        { "refId": "B", "expr": "node_memory_SwapTotal_bytes{instance=~\"$instance\"}", "legendFormat": "total {{instance}}" }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Disk",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Filesystem usage by mountpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "100 * (1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs|devtmpfs\"})", "legendFormat": "{{mountpoint}}" }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Disk I/O bytes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m])",  "legendFormat": "read  {{device}}" },
        { "refId": "B", "expr": "-rate(node_disk_written_bytes_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m])", "legendFormat": "write {{device}}" }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Disk IOPS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rate(node_disk_reads_completed_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m])",   "legendFormat": "read  {{device}}" },
        { "refId": "B", "expr": "rate(node_disk_writes_completed_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m])",  "legendFormat": "write {{device}}" }
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Disk I/O latency (avg)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rate(node_disk_read_time_seconds_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m]) / clamp_min(rate(node_disk_reads_completed_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m]), 1)",   "legendFormat": "read  {{device}}" },
        { "refId": "B", "expr": "rate(node_disk_write_time_seconds_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m]) / clamp_min(rate(node_disk_writes_completed_total{instance=~\"$instance\",device!~\"loop.*|ram.*|fd.*\"}[5m]), 1)",  "legendFormat": "write {{device}}" }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Network throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\",device!~\"lo|docker.*|veth.*|cni.*|flannel.*\"}[5m]) * 8",  "legendFormat": "rx {{device}}" },
        { "refId": "B", "expr": "-rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!~\"lo|docker.*|veth.*|cni.*|flannel.*\"}[5m]) * 8", "legendFormat": "tx {{device}}" }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Network errors + drops",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "rate(node_network_receive_errs_total{instance=~\"$instance\",device!~\"lo\"}[5m])",  "legendFormat": "rx errs {{device}}" },
        { "refId": "B", "expr": "rate(node_network_transmit_errs_total{instance=~\"$instance\",device!~\"lo\"}[5m])", "legendFormat": "tx errs {{device}}" },
        { "refId": "C", "expr": "rate(node_network_receive_drop_total{instance=~\"$instance\",device!~\"lo\"}[5m])",  "legendFormat": "rx drop {{device}}" },
        { "refId": "D", "expr": "rate(node_network_transmit_drop_total{instance=~\"$instance\",device!~\"lo\"}[5m])", "legendFormat": "tx drop {{device}}" }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Process + file descriptors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Processes (running + blocked)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
