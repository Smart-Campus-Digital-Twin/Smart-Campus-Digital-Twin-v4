      "targets": [
        { "refId": "A", "expr": "node_procs_running{instance=~\"$instance\"}",  "legendFormat": "running {{instance}}" },
        { "refId": "B", "expr": "node_procs_blocked{instance=~\"$instance\"}",  "legendFormat": "blocked {{instance}}" }
      ]
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Open file descriptors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "node_filefd_allocated{instance=~\"$instance\"}", "legendFormat": "allocated {{instance}}" },
        { "refId": "B", "expr": "node_filefd_maximum{instance=~\"$instance\"}",   "legendFormat": "max {{instance}}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["system", "node-exporter", "infra"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(node_uname_info, instance)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "options": []
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Droplet System Overview",
  "uid": "droplet-system-overview",
  "version": 1,
  "weekStart": ""
