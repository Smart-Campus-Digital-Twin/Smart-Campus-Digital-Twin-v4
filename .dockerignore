# Version control — never needed inside an image
.git
.gitignore
.github

# Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# Tests — not shipped in production images
tests/
conftest.py
**/.pytest_cache/

# ML training artifacts — large binaries never needed inside any image.
# datasets/ is required by services/ml-retrain (CSV fallback), so we
# only exclude processed/ and models/.
services/ml-prediction/processed/
services/ml-prediction/models/
services/**/__pycache__/
services/**/*.pyc

# Dev/CI tooling
memory/
.github/
docker-compose.dev.yml
pyproject.toml
Makefile

# Frontend — exclude build artifacts (rebuilt inside image)
services/frontend/node_modules/
services/frontend/.next/
services/frontend/.env*
services/sim-control/frontend/node_modules/
services/sim-control/frontend/.next/

# Secrets — must never be baked into images
env/*.env
.env
.env.*
